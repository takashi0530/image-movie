# すべて任意。未設定時は app/config.py のデフォルトが使われる。
# IMAGE_MOVIE_WIDTH=1920
# IMAGE_MOVIE_HEIGHT=1080
# IMAGE_MOVIE_SECONDS_PER_IMAGE=2.5
# IMAGE_MOVIE_OUTPUT_FPS=30
# IMAGE_MOVIE_MAX_FILES=300
# IMAGE_MOVIE_MAX_FILE_SIZE_MB=25
# IMAGE_MOVIE_JOB_TTL_SECONDS=3600
# JSON 配列で指定: IMAGE_MOVIE_CORS_ORIGINS=["http://localhost:3000"]
